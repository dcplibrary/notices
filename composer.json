{
    "name": "dcplibrary/notifications",
    "description": "Laravel package for tracking and analyzing Polaris ILS notifications with Shoutbomb integration",
    "type": "library",
    "keywords": ["laravel", "polaris", "ils", "notifications", "shoutbomb", "library"],
    "license": "MIT",
    "authors": [
        {
            "name": "Brian Lashbrook",
            "email": "blashbrook@dcplibrary.org"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Dcplibrary\\Notifications\\": "src/",
            "Dcplibrary\\Notifications\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dcplibrary\\Notifications\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dcplibrary\\Notifications\\NotificationsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
