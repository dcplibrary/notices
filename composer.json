{
    "name": "dcplibrary/polaris-notifications",
    "description": "Laravel package for tracking and analyzing Polaris ILS notifications with Shoutbomb integration",
    "type": "library",
    "keywords": ["laravel", "polaris", "ils", "notifications", "shoutbomb", "library"],
    "license": "MIT",
    "authors": [
        {
            "name": "Brian Lashbrook",
            "email": "blashbrook@dcplibrary.org"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/database": "^10.0|^11.0",
        "illuminate/console": "^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Dcplibrary\\PolarisNotifications\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dcplibrary\\PolarisNotifications\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dcplibrary\\PolarisNotifications\\PolarisNotificationsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
